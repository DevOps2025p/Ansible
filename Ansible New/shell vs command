- name: shell vs command
  hosts: frontend
  tasks:
  - name: redirect the output file
    #ansible.builtin.command: ls -lrth > /tmp/ansible_output.txt
    ansible.builtin.shell: ls -lrth > /tmp/ansible_output.txt
    register: command_output
  - name: print the out of the command
    ansible.builtin.debug:
      msg: "{{ command_output }}"